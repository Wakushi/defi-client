# Copy to `.env` and/or `.env.local` (Next.js and scripts load `.env.local` over `.env`).

# Session cookie (HS256). e.g. openssl rand -base64 48
SESSION_SECRET=
# Optional session duration in seconds (default 604800 = 7 days)
# SESSION_MAX_AGE_SEC=604800

# Dynamic Node SDK — required for web signup (createWalletAccount) and signing trades.
DYNAMIC_AUTH_TOKEN=your_api_token_here
DYNAMIC_ENVIRONMENT_ID=your_environment_id_here

# PostgreSQL connection URL, e.g. postgres://user:pass@localhost:5432/defiduel
DATABASE_URL=postgres://user:password@localhost:5432/defiduel

# Optional: after signup, fund the user with native gas then call getFreeDai() (same chain).
PRIVATE_KEY_GAS_DISPATCHER=0x
GAS_DISPATCH_AMOUNT_ETH=0.002

USDC_FAUCET_CONTRACT_ADDRESS=0x0000000000000000000000000000000000000000
FAUCET_RPC_URL=https://
FAUCET_CHAIN_ID=421614
# Plancher gas (wei) pour gros appels contrat ex. openTrade — si « intrinsic gas too low », monter (défaut 8_000_000).
# FAUCET_CONTRACT_CALL_GAS_MIN=8000000

# Uniswap Trading API — démo swaps sur Ethereum mainnet uniquement (voir composant accueil)
# https://hub.uniswap.org/
# UNISWAP_TRADE_API_KEY=
# RPC mainnet pour signer / envoyer les txs (Infura, Alchemy, etc.)
# MAINNET_RPC_URL=https://
# Montants de démo (optionnel) : wei ETH et plus petite unité USDC (6 déc.)
# UNISWAP_MAINNET_DEMO_ETH_WEI=1000000000000000
# UNISWAP_MAINNET_DEMO_USDC_RAW=1000000
# USDC mainnet par défaut Circle ; surcharge si besoin
# UNISWAP_MAINNET_USDC_ADDRESS=0xA0b86991c6218b36c1d19D4a2e9Eb0cE3606eB48

# Mobula — portefeuille (GET /api/1/wallet/portfolio). Sans clé, l’API démo est utilisée (limitée).
# MOBULA_API_KEY=
# Chaînes séparées par des virgules (slugs Mobula), ex. arbitrum,base,ethereum
# MOBULA_BLOCKCHAINS=arbitrum,base
# Seuil de liquidité mini (USD) — 0 pour garder les petits jetons
# MOBULA_MIN_LIQ_USD=0
# MOBULA_TESTNET=true
# MOBULA_FETCH_ALL_CHAINS=true

# Duel DeFi — paires Gains (REST) + positions temps réel (WebSocket, URL publique pour le navigateur)
# DUEL_DEFI_API_BASE_URL=http://46.202.173.162:3001
# NEXT_PUBLIC_DUEL_DEFI_WS_URL=ws://46.202.173.162:3001/ws/positions

GNS_COLLATERAL_TOKEN_ADDRESS=0x
# GNS_DIAMOND_ADDRESS=0x
# GNS_REFERRER_ADDRESS=0x0000000000000000000000000000000000000000
# GNS_MAX_SLIPPAGE_P=3000
